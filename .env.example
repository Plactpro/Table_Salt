# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# Public HTTPS URL of this deployment (used for webhook registration, QR codes, etc.)
# On AWS: set to your ALB DNS name or custom domain, e.g. https://app.yourdomain.com
APP_URL=https://your-domain.com

# Strong random secret for signing session cookies (min 32 chars)
# Generate: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# ─── Database ─────────────────────────────────────────────────────────────────
# AWS RDS PostgreSQL connection string
# Format: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@your-rds-endpoint.rds.amazonaws.com:5432/tablesalt?sslmode=require

# ─── AWS ─────────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# S3 bucket for file uploads (menu images, ad creatives, attachments)
# Create bucket in same region as app.
# Required CORS rule on the bucket (add via S3 console → Permissions → CORS):
#   [{ "AllowedOrigins": ["*"], "AllowedMethods": ["GET"],
#      "AllowedHeaders": ["*"], "MaxAgeSeconds": 3000 },
#    { "AllowedOrigins": ["https://your-domain.com"],
#      "AllowedMethods": ["PUT", "POST"],
#      "AllowedHeaders": ["*"], "MaxAgeSeconds": 3000 }]
# Objects are stored as uploads/{uuid}/{originalname} with public-read ACL or
# pre-signed URL policy depending on your bucket access policy.
AWS_S3_BUCKET=your-tablesalt-uploads-bucket

# ─── Redis ───────────────────────────────────────────────────────────────────
# AWS ElastiCache Redis URL — required when running 2+ app instances
# (enables WebSocket pub/sub so events cross instances)
# Format: redis://your-redis-endpoint.cache.amazonaws.com:6379
REDIS_URL=redis://your-elasticache-endpoint:6379

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Razorpay ────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=...

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# AWS SES recommended: smtp.eu-west-1.amazonaws.com
SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=your-ses-smtp-user
SMTP_PASS=your-ses-smtp-password
SMTP_FROM=noreply@yourdomain.com

# ─── Push Notifications (optional) ───────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
