# ============================================================
# TABLE SALT — RESTAURANT MANAGEMENT SYSTEM
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control
# Generate secrets: openssl rand -hex 32
# ============================================================

# ─── Application ─────────────────────────────────────────────
NODE_ENV=production
PORT=5000
# Public HTTPS URL of this deployment (used for webhook registration, QR codes, etc.)
APP_URL=https://your-domain.com
# Strong random secret for signing session cookies (min 32 chars)
# Generate: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
# JWT Secret for API token signing
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
JWT_EXPIRES_IN=7d

# ─── Database ────────────────────────────────────────────────
# AWS RDS PostgreSQL connection string
DATABASE_URL=postgresql://user:password@your-rds-endpoint.rds.amazonaws.com:5432/tablesalt?sslmode=require

# ─── AWS ─────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=your-tablesalt-uploads-bucket
AWS_S3_URL=https://your-tablesalt-uploads-bucket.s3.amazonaws.com

# ─── Redis ───────────────────────────────────────────────────
# AWS ElastiCache Redis URL — required when running 2+ app instances
REDIS_URL=redis://your-elasticache-endpoint:6379

# ─── Stripe (International Payments) ─────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Razorpay (India Payments) ───────────────────────────────
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── Email (SMTP) ────────────────────────────────────────────
SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=your-ses-smtp-user
SMTP_PASS=your-ses-smtp-password
SMTP_FROM=noreply@yourdomain.com

# ─── Twilio (SMS & WhatsApp OTP) ─────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ─── Google (OAuth & Maps) ───────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ─── Push Notifications (VAPID) ──────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@yourdomain.com

# ─── Cloudinary (Image Uploads - Alternative to S3) ──────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ─── OpenAI (AI Features) ────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key

# ─── Rate Limiting & Security ────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
BCRYPT_ROUNDS=12
CORS_ORIGIN=https://your-domain.com

# ─── Staff Defaults ──────────────────────────────────────────
# Password used by seed and migration scripts for initial staff accounts
# Required in production — app will refuse to start without it
DEFAULT_STAFF_PASSWORD=changeme

# ─── Multi-Tenant ────────────────────────────────────────────
DEFAULT_TENANT_ID=1
MAX_LOCATIONS_PER_TENANT=50
